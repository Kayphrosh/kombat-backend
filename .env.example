DATABASE_URL=postgres://user:password@localhost:5432/wager_db
PORT=3000
RUST_LOG=wager_api=debug,tower_http=debug
AUTH_JWT_SECRET=your-jwt-secret-here
AUTH_ADMIN_TOKEN=your-admin-token-here
AGENT_API_TOKEN=your-agent-token-here
# Minimum confidence (0–1) for a proposal to be auto-accepted without admin review.
# Proposals below this threshold are always queued for manual review.
AGENT_MIN_AUTO_ACCEPT_CONFIDENCE=0.80

# Webhooks
# HMAC-SHA256 secret for the generic match-result webhook
WEBHOOK_SECRET=your-webhook-secret-here

# Dynamic SDK (required for POST /api/auth/verify)
DYNAMIC_ENVIRONMENT_ID=your-dynamic-environment-id

# Sui
SUI_NETWORK=testnet
SUI_TESTNET_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_MAINNET_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_TESTNET_PACKAGE_ID=
SUI_MAINNET_PACKAGE_ID=
SUI_TESTNET_USDC_COIN_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC
SUI_MAINNET_USDC_COIN_TYPE=0xdba34672e30cb065b1f93e3ab55318768fd6fef66c15942c9f7cb846e2f900e7::usdc::USDC
SUI_STAKING_MODULE=tournament_staking
# Move module name of the P2P wager contract (used by the wager PTB builders)
SUI_WAGER_MODULE=wager
# Published wager package (separate from the staking package).
# Testnet deployment: 0xae1b02ef5fdabec4d8d508d08a43c077296ccd6dd273ba09bcad24bec987e2ea
SUI_TESTNET_WAGER_PACKAGE_ID=
SUI_MAINNET_WAGER_PACKAGE_ID=
# 64-byte ed25519 keypair (JSON array) used to auto-resolve wagers on-chain.
# Its address must equal each wager's on-chain `resolver` and hold SUI for gas.
PLATFORM_SIGNER_KEYPAIR=

# Tournament data provider (GRID)
GRID_ENABLED=true
GRID_API_KEY=
# Public GRID examples use https://api-op.grid.gg/central-data/graphql.
# Override these only if the GRID portal gives you a different endpoint.
GRID_BASE_URL=https://api-op.grid.gg
GRID_MATCHES_PATH=central-data/graphql
GRID_AUTH_HEADER=x-api-key
GRID_API_STYLE=graphql
# Optional: paste the exact match query from GRID docs/portal if it differs
# from the backend's minimal default query.
GRID_GRAPHQL_QUERY=
GRID_DEFAULT_STATUSES=
# Optional comma-separated game slugs, e.g. csgo,dota2,lol
GRID_VIDEOGAME_SLUGS=lol,csgo,dota2,valorant
GRID_PER_PAGE=100
GRID_MAX_PAGES=3

# Walrus durable evidence/artifacts
WALRUS_ENABLED=false
WALRUS_NETWORK=testnet
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=5
WALRUS_MAX_UPLOAD_BYTES=1048576

# Funding/on-ramp provider router
RAMP_PRIMARY_PROVIDER=dynamic_native
DYNAMIC_ONRAMP_ENABLED=true
MANUAL_CRYPTO_DEPOSIT_ENABLED=true
RAMP_DEFAULT_NETWORK=sui
RAMP_DEFAULT_CRYPTO_CURRENCY=USDC
RAMP_DEFAULT_FIAT_CURRENCY=USD
RAMP_PARTNER_FEE_BPS=0

# Transak fallback (optional)
TRANSAK_API_KEY=
TRANSAK_PARTNER_API_KEY=
TRANSAK_ENVIRONMENT=production
TRANSAK_REFERRER_DOMAIN=localhost
TRANSAK_DEFAULT_NETWORK=sui
TRANSAK_DEFAULT_CRYPTO_CURRENCY=USDC
TRANSAK_DEFAULT_FIAT_CURRENCY=USD
TRANSAK_PARTNER_FEE_BPS=0

# File uploads (optional — enables POST /api/uploads and avatar upload)
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:3000
